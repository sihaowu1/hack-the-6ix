# OpenRouter API key used by the AI agents (server-side only).
# Without a key, the server falls back to a deterministic offline template generator
# so the app still runs end-to-end.
OPENROUTER_API_KEY=

# Auth0 (optional). When unset, the app runs fully anonymous — login is only
# needed for signed-in features like GitHub export. Set all three VITE_* vars
# plus AUTH0_DOMAIN/AUTH0_AUDIENCE for the server JWT check.
# VITE_AUTH0_DOMAIN=your-tenant.auth0.com
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=https://api.motionforge.local
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://api.motionforge.local

# Optional overrides (defaults live in config/default.config.json)
# PORT=5174
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4.5
# BLENDER_MCP_ENABLED=true
# REMOTION_GL=angle
